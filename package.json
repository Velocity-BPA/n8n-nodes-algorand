{
  "name": "@velocity-bpa/n8n-nodes-algorand",
  "version": "1.0.0",
  "description": "n8n community node for Algorand blockchain API integration",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "algorand",
    "blockchain",
    "crypto"
  ],
  "license": "bsl-catalog",
  "homepage": "https://github.com/velocity-bpa/n8n-nodes-algorand",
  "author": {
    "name": "Velocity BPA",
    "email": "support@velocitybpa.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/velocity-bpa/n8n-nodes-algorand.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.1.4",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/**/*"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/AlgorandApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Algorand/Algorand.node.js"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^7.15.0",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "eslint": "^8.56.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "prettier": "^3.3.2",
    "typescript": "^5.5.3",
    "n8n-workflow": "*"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "dependencies": {
    "axios": "^1.7.4"
  }
}